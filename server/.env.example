# Copia este archivo a .env y cambia los valores en produccion.

# --- Base de datos ---
# Dev (arranca sin instalar nada): SQLite
DATABASE_URL="file:./dev.db"
# Produccion (alto trafico): PostgreSQL con pool de conexiones (PgBouncer recomendado)
# DATABASE_URL="postgresql://usuario:password@host:5432/sello?schema=public&connection_limit=20&pool_timeout=20"

# --- Seguridad ---
# GENERA UNO REAL:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"
JWT_EXPIRES_IN="7d"

# Origen permitido del frontend (CORS). En prod usa tu dominio real.
CORS_ORIGIN="http://localhost:5173"

PORT=4000

# Dias que se conserva una tarjeta ya canjeada antes de archivarla/depurarla
RETENTION_DAYS=90

# Duracion de la prueba gratis para nuevas marcas (dias)
TRIAL_DAYS=3

# --- Email / verificacion de correo (opcional) ---
# Sin proveedor: modo dev (el codigo se ve en consola y en el panel de dueño).
EMAIL_ENABLED=false
EMAIL_API_KEY=""
EMAIL_FROM="no-reply@sello.app"

# --- Wallet (opcional; deja vacio para desactivar) ---
# Apple Wallet: rutas a certificados .pem y password
APPLE_WALLET_ENABLED=false
# Google Wallet: credenciales de service account (issuer)
GOOGLE_WALLET_ENABLED=false
