# Copia este archivo a .env y cambia los valores en produccion.

# --- Base de datos ---
# Dev (arranca sin instalar nada): SQLite
DATABASE_URL="file:./dev.db"
# Produccion (alto trafico): PostgreSQL con pool de conexiones (PgBouncer recomendado)
# DATABASE_URL="postgresql://usuario:password@host:5432/sello?schema=public&connection_limit=20&pool_timeout=20"

# --- Seguridad ---
# GENERA UNO REAL:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"
JWT_EXPIRES_IN="7d"

# Origen permitido del frontend (CORS). En prod usa tu dominio real.
CORS_ORIGIN="http://localhost:5173"

PORT=4000

# Dias que se conserva una tarjeta ya canjeada antes de archivarla/depurarla
RETENTION_DAYS=90

# Duracion de la prueba gratis para nuevas marcas (dias)
TRIAL_DAYS=3

# --- Email / verificacion de correo (opcional) ---
# Sin proveedor: modo dev (el codigo se ve en consola y en el panel de dueño).
EMAIL_ENABLED=false
EMAIL_API_KEY=""
EMAIL_FROM="no-reply@sello.app"

# --- Wallet (opcional; deja vacio para desactivar) ---
# Apple Wallet: rutas a certificados .pem y password
APPLE_WALLET_ENABLED=false
# Google Wallet: credenciales de service account (issuer)
GOOGLE_WALLET_ENABLED=false

# URL publica del frontend (para los links de tarjeta/QR que manda el bot)
PUBLIC_URL="http://localhost:5173"

# ---------------------------------------------------------------------------
# Chatbot omnicanal (WhatsApp -> luego Messenger/Instagram)
# ---------------------------------------------------------------------------
# WhatsApp Business Cloud API (OFICIAL de Meta -> NO banean el numero).
# Sin esto: el bot corre en MODO DEV (mensajes salientes van a la consola,
# el webhook simulado funciona para probar la logica).
# Setup: developers.facebook.com -> crear app -> agregar producto "WhatsApp".
WHATSAPP_ENABLED=false
WHATSAPP_TOKEN=""                 # access token (permanente / system user)
WHATSAPP_PHONE_NUMBER_ID=""       # Phone number ID que da Meta
WHATSAPP_VERIFY_TOKEN="fidelix-verify"  # token que vos inventas para el reto del webhook (GET)
WHATSAPP_APP_SECRET=""            # App Secret (para verificar la firma X-Hub-Signature-256)
WHATSAPP_API_VERSION="v21.0"

# Capa de IA del bot (Claude). Sin API key -> el bot corre en modo solo-flujos.
BOT_AI_ENABLED=false
ANTHROPIC_API_KEY=""
# claude-opus-4-8 (mas capaz) por defecto. Para alto volumen: claude-haiku-4-5 (mas barato/rapido).
BOT_AI_MODEL="claude-opus-4-8"
BOT_AI_MAX_STEPS=6

# Contacto humano (numero de WhatsApp de Movix, formato E.164 SIN "+")
BOT_HUMAN_HANDOFF="50670863466"
# A donde avisar de leads de ventas captados por el bot (correo o telefono)
BOT_SALES_INBOX=""
