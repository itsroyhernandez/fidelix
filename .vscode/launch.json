{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Fidelix: API (server)",
      "cwd": "${workspaceFolder}/server",
      "program": "${workspaceFolder}/server/src/server.js",
      "console": "integratedTerminal"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Fidelix: Web (vite)",
      "cwd": "${workspaceFolder}/web",
      "program": "${workspaceFolder}/web/node_modules/vite/bin/vite.js",
      "console": "integratedTerminal"
    }
  ],
  "compounds": [
    {
      "name": "Fidelix: API + Web",
      "configurations": ["Fidelix: API (server)", "Fidelix: Web (vite)"],
      "stopAll": true
    }
  ]
}
